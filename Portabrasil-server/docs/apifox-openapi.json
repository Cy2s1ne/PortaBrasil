{
  "openapi": "3.0.3",
  "info": {
    "title": "PortaBrasil Flask 后端接口",
    "version": "0.1.0",
    "description": "PortaBrasil PDF 单据上传、解析入库、业务查询和费用明细接口。可直接导入 Apifox。"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:5001",
      "description": "本地开发服务"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "服务健康检查"
    },
    {
      "name": "Auth",
      "description": "用户登录、注册、鉴权和用户管理"
    },
    {
      "name": "Files",
      "description": "PDF 文件上传、解析、查询"
    },
    {
      "name": "Documents",
      "description": "解析文本直接入库"
    },
    {
      "name": "Business",
      "description": "海关业务主表与费用明细查询"
    },
    {
      "name": "Tasks",
      "description": "PDF 解析任务查询"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["Health"],
        "summary": "健康检查",
        "description": "检查 Flask 服务是否正常运行，并返回当前数据库后端类型。",
        "operationId": "healthCheck",
        "security": [],
        "responses": {
          "200": {
            "description": "服务正常",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                },
                "examples": {
                  "ok": {
                    "summary": "正常响应",
                    "value": {
                      "status": "ok",
                      "database": "mysql"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "账号登录",
        "description": "支持 username 或 email 登录，校验密码（SHA-256）后返回 JWT。",
        "operationId": "authLogin",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "examples": {
                "byUsername": {
                  "summary": "用户名登录",
                  "value": {
                    "username": "admin",
                    "password": "admin123456"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokenResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "公开注册",
        "description": "注册新用户并自动分配默认角色（由 DEFAULT_REGISTER_ROLE 控制，默认 FORWARDER），成功后直接返回 JWT。",
        "operationId": "authRegister",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              },
              "examples": {
                "sample": {
                  "summary": "注册示例",
                  "value": {
                    "username": "newuser",
                    "password": "123456",
                    "email": "newuser@example.com",
                    "real_name": "新用户"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "注册成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokenResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/api/auth/forgot-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "忘记密码重置",
        "description": "通过用户名+邮箱重置密码（内网简化版本）。",
        "operationId": "authForgotPassword",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForgotPasswordRequest"
              },
              "examples": {
                "sample": {
                  "summary": "重置示例",
                  "value": {
                    "username": "admin",
                    "email": "admin@portabrasil.local",
                    "new_password": "newpass123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "重置成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "密码重置成功，请使用新密码登录"
                    }
                  },
                  "required": ["message"]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "获取当前登录用户",
        "description": "根据 Bearer Token 返回当前用户信息和角色。",
        "operationId": "authMe",
        "responses": {
          "200": {
            "description": "当前用户信息",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrentUserResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/auth/users": {
      "post": {
        "tags": ["Auth"],
        "summary": "管理员创建用户",
        "description": "仅 SUPER_ADMIN/ADMIN 可调用。创建用户并分配角色。",
        "operationId": "createUserByAdmin",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserRequest"
              },
              "examples": {
                "sample": {
                  "summary": "创建用户示例",
                  "value": {
                    "username": "zhangsan",
                    "password": "123456",
                    "real_name": "张三",
                    "email": "zhangsan@example.com",
                    "role_codes": ["CUSTOMS"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrentUserResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/api/files/upload": {
      "post": {
        "tags": ["Files"],
        "summary": "上传 PDF 文件",
        "description": "上传 PDF。默认 parse=true，会立即调用智谱 PDF 解析并将结果写入数据库；parse=false 时只保存文件记录。",
        "operationId": "uploadPdfFile",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "PDF 文件"
                  },
                  "parse": {
                    "type": "boolean",
                    "default": true,
                    "description": "是否上传后立即解析入库"
                  }
                }
              },
              "encoding": {
                "file": {
                  "contentType": "application/pdf"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "重复文件或已有文件返回",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileUploadResponse"
                }
              }
            }
          },
          "201": {
            "description": "文件上传成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileUploadResponse"
                },
                "examples": {
                  "uploadedWithoutParse": {
                    "summary": "parse=false",
                    "value": {
                      "duplicated": false,
                      "file": {
                        "id": 1,
                        "file_name": "p2s.pdf",
                        "file_path": "/path/to/uploads/20260415/xxx.pdf",
                        "file_size": 155514,
                        "file_hash": "sha256hex",
                        "page_count": 1,
                        "parse_status": "PENDING",
                        "upload_time": "2026-04-15 22:00:00",
                        "remark": null
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        }
      }
    },
    "/api/files/{file_id}/parse": {
      "post": {
        "tags": ["Files"],
        "summary": "解析已有 PDF 文件",
        "description": "对已上传的 PDF 文件发起解析任务，解析成功后写入 customs_business 和 customs_business_fee_item。",
        "operationId": "parseExistingFile",
        "parameters": [
          {
            "$ref": "#/components/parameters/FileId"
          }
        ],
        "responses": {
          "200": {
            "description": "解析成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ParseFileResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        }
      }
    },
    "/api/files": {
      "get": {
        "tags": ["Files"],
        "summary": "查询 PDF 文件列表",
        "description": "分页查询上传过的 PDF 文件，可按解析状态筛选。",
        "operationId": "listFiles",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "每页数量，最大 100",
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "偏移量",
            "schema": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "解析状态",
            "schema": {
              "$ref": "#/components/schemas/ParseStatus"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "文件列表",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/files/{file_id}": {
      "get": {
        "tags": ["Files"],
        "summary": "查询 PDF 文件详情",
        "description": "查询 PDF 文件记录、关联解析任务和来源业务记录。",
        "operationId": "getFileDetail",
        "parameters": [
          {
            "$ref": "#/components/parameters/FileId"
          }
        ],
        "responses": {
          "200": {
            "description": "文件详情",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileDetailResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/documents/from-text": {
      "post": {
        "tags": ["Documents"],
        "summary": "解析文本直接入库",
        "description": "把智谱返回的 content 或已有 OCR 文本直接解析并写入数据库。适合先绕过 PDF 上传流程测试规则解析。",
        "operationId": "createDocumentFromText",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDocumentFromTextRequest"
              },
              "examples": {
                "sample": {
                  "summary": "最小示例",
                  "value": {
                    "raw_text": "LOGIMEX COMERCIO EXTERIOR LTDA ... S/Ref.: 20250528000158 ... TOTAL => 228.389,13 200.897,37 ...",
                    "file_id": null,
                    "source_page_no": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "业务记录写入成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BusinessDetailResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        }
      }
    },
    "/api/business": {
      "get": {
        "tags": ["Business"],
        "summary": "查询业务列表",
        "description": "分页查询 customs_business。q 会匹配 S/Ref、Invoice、客户名称、MAWB/MBL。",
        "operationId": "listBusiness",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "description": "搜索关键字",
            "schema": {
              "type": "string",
              "example": "20250528000158"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "每页数量，最大 100",
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "偏移量",
            "schema": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "业务列表",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BusinessListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/business/{business_id}": {
      "get": {
        "tags": ["Business"],
        "summary": "查询业务详情",
        "description": "查询单条 customs_business，并带出 fee_items。",
        "operationId": "getBusinessDetail",
        "parameters": [
          {
            "$ref": "#/components/parameters/BusinessId"
          }
        ],
        "responses": {
          "200": {
            "description": "业务详情",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BusinessDetailResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/business/{business_id}/fees": {
      "get": {
        "tags": ["Business"],
        "summary": "查询业务费用明细",
        "description": "查询指定业务下的 customs_business_fee_item 列表。",
        "operationId": "listBusinessFees",
        "parameters": [
          {
            "$ref": "#/components/parameters/BusinessId"
          }
        ],
        "responses": {
          "200": {
            "description": "费用明细列表",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeeListResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/tasks/{task_id}": {
      "get": {
        "tags": ["Tasks"],
        "summary": "查询解析任务详情",
        "description": "查询 pdf_parse_task 记录，包括任务状态、错误信息和 raw_result。",
        "operationId": "getTaskDetail",
        "parameters": [
          {
            "$ref": "#/components/parameters/TaskId"
          }
        ],
        "responses": {
          "200": {
            "description": "任务详情",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskDetailResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "在请求头中添加：Authorization: Bearer <access_token>"
      }
    },
    "parameters": {
      "FileId": {
        "name": "file_id",
        "in": "path",
        "required": true,
        "description": "pdf_file.id",
        "schema": {
          "type": "integer",
          "example": 1
        }
      },
      "BusinessId": {
        "name": "business_id",
        "in": "path",
        "required": true,
        "description": "customs_business.id",
        "schema": {
          "type": "integer",
          "example": 1
        }
      },
      "TaskId": {
        "name": "task_id",
        "in": "path",
        "required": true,
        "description": "pdf_parse_task.id",
        "schema": {
          "type": "integer",
          "example": 1
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "请求参数错误",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "badRequest": {
                "value": {
                  "error": "缺少 multipart 字段 file"
                }
              }
            }
          }
        }
      },
      "Unauthorized": {
        "description": "未登录或 Token 无效",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "unauthorized": {
                "value": {
                  "error": "缺少或无效 Authorization Bearer Token"
                }
              }
            }
          }
        }
      },
      "Forbidden": {
        "description": "权限不足",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "forbidden": {
                "value": {
                  "error": "权限不足"
                }
              }
            }
          }
        }
      },
      "Conflict": {
        "description": "资源冲突（如用户名已存在）",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "conflict": {
                "value": {
                  "error": "用户名已存在"
                }
              }
            }
          }
        }
      },
      "NotFound": {
        "description": "资源不存在",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "notFound": {
                "value": {
                  "error": "业务记录不存在"
                }
              }
            }
          }
        }
      },
      "ServerError": {
        "description": "服务端错误",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "missingKey": {
                "value": {
                  "error": "ZHIPU_API_KEY 未配置，无法调用智谱 PDF 解析接口"
                }
              }
            }
          }
        }
      }
    },
    "schemas": {
      "UserProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "username": {
            "type": "string",
            "example": "admin"
          },
          "real_name": {
            "type": "string",
            "nullable": true,
            "example": "系统管理员"
          },
          "phone": {
            "type": "string",
            "nullable": true,
            "example": "13800000000"
          },
          "email": {
            "type": "string",
            "nullable": true,
            "example": "admin@portabrasil.local"
          },
          "status": {
            "type": "integer",
            "enum": [0, 1],
            "example": 1
          },
          "created_at": {
            "type": "string",
            "example": "2026-04-16 12:30:00"
          },
          "updated_at": {
            "type": "string",
            "example": "2026-04-16 12:30:00"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string",
              "example": "SUPER_ADMIN"
            }
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["password"],
        "properties": {
          "username": {
            "type": "string",
            "description": "用户名，username/email/account 三选一",
            "example": "admin"
          },
          "email": {
            "type": "string",
            "description": "邮箱，username/email/account 三选一",
            "example": "admin@portabrasil.local"
          },
          "account": {
            "type": "string",
            "description": "账号别名字段，等同 username/email",
            "example": "admin"
          },
          "password": {
            "type": "string",
            "example": "admin123456"
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string",
            "example": "newuser"
          },
          "password": {
            "type": "string",
            "example": "123456"
          },
          "real_name": {
            "type": "string",
            "nullable": true,
            "example": "新用户"
          },
          "phone": {
            "type": "string",
            "nullable": true,
            "example": "13800000000"
          },
          "email": {
